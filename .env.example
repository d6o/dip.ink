# ---- required -------------------------------------------------------------

# OpenAI API key. Used for embeddings (text-embedding-3-small, ~$0.02/1M tokens)
# and — unless you point LLM_BASE_URL elsewhere — for graph extraction and
# answer distillation too. One key runs the whole stack.
OPENAI_API_KEY=sk-...

# Your PRIVATE wiki repo (created from template/ — see README step 1).
# HTTPS URL; the token needs read+write (wiki_note_drop pushes notes).
WIKI_REPO_URL=https://github.com/you/my-memory.git
WIKI_REPO_TOKEN=ghp_...
# Username sent with the token as HTTP basic auth. For GitHub PATs any
# non-empty value works; for Gitea/GitLab use the account name.
WIKI_REPO_USER=token

# Password for the bundled Neo4j (pick anything strong).
NEO4J_PASSWORD=change-me

# ---- optional: extraction LLM ----------------------------------------------

# Leave unset to extract with OpenAI (LLM_MODEL below). To use a different
# OpenAI-compatible endpoint (LiteLLM proxy, local server, ...), set all three:
#LLM_BASE_URL=http://litellm:4000/v1
#LLM_API_KEY=sk-...
LLM_MODEL=gpt-4.1-mini

# Model used by graph_answer's distiller (defaults to LLM_MODEL).
#DISTILL_MODEL=gpt-4.1-mini

# ---- optional: tuning -------------------------------------------------------

# Graphiti group id → Neo4j database name for your notes.
#GROUP_ID=main
# Notes ingested per tick / seconds between ticks.
#INGEST_BATCH_SIZE=15
#INGEST_INTERVAL=900
# Neo4j memory (raise for big graphs).
#NEO4J_HEAP=1G
#NEO4J_PAGECACHE=512M
# Extra hostnames allowed to reach wiki-mcp (add your ingress hostname).
#WIKI_MCP_ALLOWED_HOSTS=localhost,127.0.0.1,wiki-mcp,memory.example.com
# A question your graph should answer with high confidence (daily healthcheck probe).
#ANSWER_PROBE=what is this memory system's note inbox called
