# ---- required -------------------------------------------------------------

# OpenAI API key. Graphiti currently uses OpenAI embeddings even when graph
# extraction/distillation use another OpenAI-compatible endpoint.
OPENAI_API_KEY=replace-with-openai-key

# Your PRIVATE wiki repo (created from template/ — see README step 1).
# HTTPS URL; the token needs read+write (wiki_note_drop pushes notes).
WIKI_REPO_URL=https://github.com/you/my-memory.git
WIKI_REPO_TOKEN=replace-with-wiki-token
# Username sent with the token as HTTP basic auth. For GitHub PATs any
# non-empty value works; for Gitea/GitLab use the account name.
WIKI_REPO_USER=token
WIKI_BRANCH=main

# Password for the bundled Neo4j.
NEO4J_PASSWORD=replace-with-strong-password

# ---- optional: extraction model ladder ------------------------------------

# Leave LLM_BASE_URL / LLM_API_KEY empty to use OpenAI directly. To use a
# different OpenAI-compatible endpoint (LiteLLM proxy, local server, ...), set
# both. LLM_MODEL_LADDER is ordered, comma-separated fallback; when empty it
# inherits LLM_MODEL.
#LLM_BASE_URL=http://litellm:4000/v1
#LLM_API_KEY=replace-with-provider-key
LLM_MODEL=gpt-4.1-mini
#LLM_MODEL_LADDER=gpt-4.1-mini,gpt-4.1-nano

# graph_answer distillation inherits extraction configuration by default. Any
# of these can override it independently; the ladder is ordered and comma-
# separated.
#DISTILL_BASE_URL=http://litellm:4000/v1
#DISTILL_API_KEY=replace-with-provider-key
#DISTILL_MODEL=gpt-4.1-mini
#DISTILL_MODEL_LADDER=gpt-4.1-mini,gpt-4.1-nano

# ---- optional: wiki embeddings, cache, and status inputs -------------------

# Wiki semantic index provider: openai (default) or fastembed (local ONNX).
# Graphiti's own embeddings still require OPENAI_API_KEY.
#WIKI_MCP_EMBED_PROVIDER=openai
#WIKI_MCP_OPENAI_MODEL=text-embedding-3-small
#WIKI_MCP_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
#WIKI_MCP_REINDEX_SEC=300
#WIKI_MCP_RETRY_INITIAL_SEC=5
#WIKI_MCP_RETRY_MAX_SEC=300
#WIKI_MCP_BACKGROUND_REINDEX=1
#WIKI_MCP_MAX_EMBED_CHARS=40000

# Persist query metrics beside the embedding cache (auto), choose a path, or
# set off to disable. These metrics and cache settings feed memory_status and
# the gaps/observability paths without changing the simple defaults.
#MCP_METRICS_PATH=auto
#ANSWER_CACHE_TTL=3600
#GRAPH_FUSION=1

# ---- optional: graph and maintenance tuning -------------------------------

# Graphiti group-id property used to isolate this corpus (not a Neo4j database).
#GROUP_ID=main
#NEO4J_MAX_POOL=50
#NEO4J_ACQ_TIMEOUT=120
# Existing edge-bearing episodes upgraded to explicit completion metadata per
# ingest tick. Status/Prometheus reads never perform this migration.
#LEGACY_UPGRADE_BATCH=25
# Notes ingested per tick / seconds between ticks.
#INGEST_BATCH_SIZE=15
#INGEST_INTERVAL=900
#ADD_EPISODE_RETRIES=4
#CIRCUIT_BREAKER_THRESHOLD=3
# Maintenance loop intervals are seconds.
#COMMUNITIES_INTERVAL=604800
#GAPS_INTERVAL=604800
#ALERTS_INTERVAL=1800
#HEALTHCHECK_INTERVAL=86400
#JANITOR_INTERVAL=2592000
# Contradiction janitor is report-only by default; explicitly opt into writes.
#JANITOR_DRY_RUN=1
#JANITOR_TOP_N=50

# Neo4j memory (raise for big graphs).
#NEO4J_HEAP=1G
#NEO4J_PAGECACHE=512M
# Extra hostnames allowed to reach the memory server (add your ingress hostname).
#MCP_ALLOWED_HOSTS=localhost,127.0.0.1,memory,memory.example.com
# A question your graph should answer with grounded confidence (healthcheck).
#ANSWER_PROBE=what is this memory system's note inbox called

# ---- curator custom providers (repository CI, not Docker Compose) ----------

# The curator runs in the wiki repository's CI rather than in this Compose
# stack. Configure PI_PROVIDER / PI_MODEL as repository variables and provide
# PI_MODELS_JSON through the repository secret/variable mechanism when using a
# custom Pi provider. Never commit a populated provider JSON document.
#PI_PROVIDER=openai
#PI_MODEL=gpt-4.1-mini
#PI_MODELS_JSON=
